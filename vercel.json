{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/whatsapp", "dest": "/api/whatsapp.js" },
    { "src": "/api/reminders", "dest": "/api/reminders.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    { "path": "/api/reminders", "schedule": "0 * * * *" }
  ]
}
